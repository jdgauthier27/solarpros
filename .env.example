# ======================
# SolarPros Configuration
# ======================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://solarpros:solarpros@localhost:5432/solarpros
DATABASE_URL_SYNC=postgresql://solarpros:solarpros@localhost:5432/solarpros
POSTGRES_USER=solarpros
POSTGRES_PASSWORD=solarpros
POSTGRES_DB=solarpros

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- API Keys ---
GOOGLE_SOLAR_API_KEY=your_google_solar_api_key_here
NREL_API_KEY=your_nrel_api_key_here
HUNTER_IO_API_KEY=your_hunter_io_api_key_here
SENDGRID_API_KEY=your_sendgrid_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- SendGrid ---
SENDGRID_FROM_EMAIL=solar@yourcompany.com
SENDGRID_FROM_NAME=SolarPros
SENDGRID_WEBHOOK_SECRET=your_webhook_secret_here

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Agent Config ---
USE_MOCK_SCRAPERS=true
USE_MOCK_APIS=true

# --- CAN-SPAM Compliance ---
COMPANY_PHYSICAL_ADDRESS="123 Solar Way, Suite 100, Los Angeles, CA 90001"
COMPANY_NAME="SolarPros Inc."

# --- Rate Limits ---
SCRAPING_RATE_PER_MINUTE=5
SOLAR_API_RATE_PER_MINUTE=100
OWNER_LOOKUP_RATE_PER_MINUTE=30
EMAIL_RATE_PER_HOUR=100

# --- Takeoff ---
TAKEOFF_STORAGE_BACKEND=local
TAKEOFF_STORAGE_PATH=/data/takeoff
TAKEOFF_MAX_UPLOAD_MB=100
TAKEOFF_CLAUDE_MODEL=claude-sonnet-4-5-20250514
TAKEOFF_CLASSIFICATION_RATE_PER_MINUTE=30
